# Copy to ".env" and fill in. None are required to RUN (offline fallbacks apply),
# but they switch the app to live data.

# Google Cloud key with Places API (and Geocoding API) enabled
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# LLM key for the natural-language recommendation blurb (Anthropic)
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Optional overrides
HOLIDAY_DB_PATH=holiday_cache.db
CACHE_TTL_HOURS=24
